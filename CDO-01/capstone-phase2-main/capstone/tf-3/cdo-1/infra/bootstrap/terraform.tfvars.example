# Bootstrap tfvars — KHÔNG commit file này nếu có giá trị nhạy cảm
# Copy file này thành terraform.tfvars trước khi apply

# GitHub repo dùng cho OIDC trust policy
# Đúng định dạng "org/repo" không có dấu nháy kép
github_repo = "truongcongtu318/capstone-phase2"

# Các biến còn lại đã có default — ghi đè nếu cần
# aws_region  = "us-east-1"
# name_prefix = "tf3-cdo1"
# environment = "sandbox"
