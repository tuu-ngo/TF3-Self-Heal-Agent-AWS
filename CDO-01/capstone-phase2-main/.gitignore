# ============================================================
# .gitignore — capstone-phase2
# Stack: Terraform · Python/FastAPI · Docker · GitHub Actions
# ============================================================

# ────────────────────────────────────────
# Terraform
# ────────────────────────────────────────

# Local .terraform directory (provider plugins, modules cache)
**/.terraform/

# Lock file: COMMIT .terraform.lock.hcl (đảm bảo reproducible provider version)
# Uncomment dòng dưới NẾU không muốn commit lock file
# **/.terraform.lock.hcl

# Terraform plan output — KHÔNG commit plan file có thể chứa secret
*.tfplan
*.tfplan.json

# Terraform state — KHÔNG bao giờ commit state thật
# (state được lưu trên S3 remote backend sau INFRA-1)
*.tfstate
*.tfstate.*
*.tfstate.backup

# tfvars có giá trị thật — chỉ commit file example
terraform.tfvars
*.tfvars
*.tfvars.json
*.auto.tfvars

# Giữ lại example files
!*.tfvars.example
!*.tfvars.json.example

# Crash log từ Terraform
crash.log
crash.*.log

# Terraform override files (local override, không thuộc về repo)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ────────────────────────────────────────
# Python / FastAPI
# ────────────────────────────────────────

# Bytecode cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/
MANIFEST

# Pytest cache và coverage
.pytest_cache/
.coverage
.coverage.*
coverage.xml
htmlcov/
*.cover

# mypy / ruff / pylint cache
.mypy_cache/
.ruff_cache/
.pylintrc.cache

# Jupyter Notebook checkpoints
.ipynb_checkpoints/

# ────────────────────────────────────────
# Docker
# ────────────────────────────────────────

# Docker build context artifact (nếu dùng docker save/export)
*.tar
*.tar.gz

# ────────────────────────────────────────
# Secrets & Credentials — KHÔNG BAO GIỜ COMMIT
# ────────────────────────────────────────

# AWS credentials (file thật — .aws/credentials, aws-credentials)
.aws/
aws-credentials
*credentials*
*_credentials
# Ngoại lệ: doc hướng dẫn setup credentials (không chứa giá trị thật)
!*credentials*.md
!*credentials*.example

# SSH keys
*.pem
*.key
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# Kubernetes kubeconfig — theo deployment-contract.md §3.A
kubeconfig
kubeconfig.*
*.kubeconfig
kube.config

# Environment files với secrets
.env
.env.*
!.env.example

# Bất kỳ file nào tên chứa "secret" hoặc "password"
*secret*
*password*
# Ngoại lệ: file example và doc
!*secret*.example
!*secret*.md
!*password*.md

# ────────────────────────────────────────
# OS & Editor
# ────────────────────────────────────────

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example

# JetBrains IDEs
.idea/
*.iml
*.iws

# Vim / Emacs swap files
*.swp
*.swo
*~
\#*\#

# ────────────────────────────────────────
# AI / Claude tooling (project-internal)
# ────────────────────────────────────────

.claude/
.examples/
CAPSTONE_EVIDENCE_PACK_FORMAT.md
TF3_SELFHEAL_LEARNER.md

# ────────────────────────────────────────
# Logs & Temp
# ────────────────────────────────────────

*.log
*.tmp
*.temp
tmp/
temp/
logs/

# ────────────────────────────────────────
# Node.js (nếu có tooling script)
# ────────────────────────────────────────

node_modules/
npm-debug.log*
yarn-error.log*
.npm/
